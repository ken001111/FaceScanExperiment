--- /dev/null
+++ b/src/utils/lidar_depth_loss.py
@@ -0,0 +1,87 @@
+# LiDAR measured-depth supervision (Paper B fork).
+# Core module contributed by the user; adapter wraps GeoSVR's loss convention.
+import torch
+import torch.nn as nn
+import torch.nn.functional as F
+
+
+class MetricLidarDepthLoss(nn.Module):
+    def __init__(self, loss_type='huber', delta=0.1):
+        super(MetricLidarDepthLoss, self).__init__()
+        self.loss_type = loss_type
+        self.delta = delta  # For Huber loss
+
+    def forward(self, rendered_depth, lidar_depth, confidence_map=None):
+        """Direct metric loss between rendered depth and iPhone LiDAR depth."""
+        if rendered_depth.shape != lidar_depth.shape:
+            rendered_depth = F.interpolate(
+                rendered_depth.unsqueeze(0).unsqueeze(0),
+                size=lidar_depth.shape[-2:],
+                mode='bilinear',
+                align_corners=False
+            ).squeeze(0).squeeze(0)
+
+        # 1. Sparsity masking: invalid/dropped LiDAR pixels are 0.0 or NaN
+        valid_mask = (lidar_depth > 0.0) & (~torch.isnan(lidar_depth))
+        if not valid_mask.any():
+            return torch.tensor(0.0, device=rendered_depth.device, requires_grad=True)
+
+        pred_valid = rendered_depth[valid_mask]
+        target_valid = lidar_depth[valid_mask]
+
+        # 2. Core metric loss (NO scale-and-shift optimization)
+        if self.loss_type == 'l1':
+            loss_per_pixel = torch.abs(pred_valid - target_valid)
+        elif self.loss_type == 'huber':
+            loss_per_pixel = F.huber_loss(pred_valid, target_valid, reduction='none', delta=self.delta)
+        else:
+            loss_per_pixel = (pred_valid - target_valid) ** 2
+
+        # 3. Confidence weighting (normalized to avoid loss-scale explosion)
+        if confidence_map is not None:
+            weights_valid = confidence_map[valid_mask]
+            loss = torch.sum(loss_per_pixel * weights_valid) / (torch.sum(weights_valid) + 1e-7)
+        else:
+            loss = torch.mean(loss_per_pixel)
+
+        return loss
+
+
+class LidarDepthLossAdapter:
+    """GeoSVR loss convention: __call__(cam, render_pkg, iteration).
+
+    Renders' expected depth is alpha-normalized on active pixels (same
+    treatment as Mast3rMetricDepthLoss); the measured map and optional
+    confidence come from cam.lidar_depth / cam.lidar_conf, loaded by the
+    data pack when frames carry depth_png / confidence_png.
+    """
+
+    def __init__(self, iter_from, iter_end, use_confidence=True,
+                 loss_type='huber', delta=0.1):
+        self.iter_from = iter_from
+        self.iter_end = iter_end
+        self.use_confidence = use_confidence
+        self.core = MetricLidarDepthLoss(loss_type=loss_type, delta=delta)
+
+    def is_active(self, iteration):
+        return self.iter_from <= iteration <= self.iter_end
+
+    def __call__(self, cam, render_pkg, iteration):
+        if not self.is_active(iteration):
+            return 0
+        if getattr(cam, "lidar_depth", None) is None:
+            return 0
+        alpha = (1 - render_pkg['raw_T'][None])          # [1,H,W]
+        depth = render_pkg['raw_depth'][[0]][None]       # expected depth
+        ref = cam.lidar_depth.cuda()                     # [h,w] metres
+        conf = cam.lidar_conf.cuda() if (self.use_confidence and
+                getattr(cam, "lidar_conf", None) is not None) else None
+        # alpha-normalize where the model is opaque enough to define depth
+        d = torch.nn.functional.interpolate(depth, size=ref.shape[-2:],
+                                            mode='bilinear', antialias=True)[0, 0]
+        a = torch.nn.functional.interpolate(alpha, size=ref.shape[-2:],
+                                            mode='bilinear', antialias=True)[0, 0]
+        act = a > 0.5
+        d = torch.where(act, d / a.clamp_min(1e-6), torch.zeros_like(d))
+        ref = torch.where(act, ref, torch.zeros_like(ref))   # -> masked invalid by core
+        return self.core(d, ref, conf)
